set nocompatible
filetype on  

syntax on

set shiftwidth=4
set nospell
set number
set ruler
set cindent
set mouse=a
set statusline+=%F
set showcmd
set tabstop=4
set expandtab
set ttimeoutlen=50
set wrap
set splitright
set background=dark
set cursorline

let &t_SI="\e[6 q"
let &t_EI="\e[2 q"

map <F8> :w <CR> :!g++ % -o %< && printf '\e[1;32m%-Compiled Successfully\e[m' <CR> :vert term ./%< <CR>
map <F5> :w <CR> :!g++ % -o %< && ./%< <CR>
map NN :NERDTreeToggle<CR>



set rtp+=~/.vim/bundle/Vundle.vim

call vundle#begin()

Plugin 'VundleVim/Vundle.vim'
" Add plugins here
Plugin 'preservim/nerdtree'
Plugin 'vim-airline/vim-airline'
Plugin 'morhetz/gruvbox'

""Themes start
Plugin 'arcticicestudio/nord-vim'
Plugin 'sainnhe/sonokai'
Plugin 'bluz71/vim-moonfly-colors'
Plugin 'glepnir/oceanic-material'
Plugin 'joshdick/onedark.vim'
""Themes end

Plugin 'octol/vim-cpp-enhanced-highlight'
Plugin 'Raimondi/delimitMate'
Plugin 'vim-syntastic/syntastic'
"Plugin 'honza/vim-snippets'
Plugin 'sirver/UltiSnips'
Plugin 'vim-scripts/AutoComplPop'


call vundle#end()

colo gruvbox

filetype plugin indent on

"vim-cpp-enhanced-setting
let g:cpp_member_variable_highlight = 1
let g:cpp_class_scope_highlight = 1

"Airline Theme
let g:airline_theme='dark'

"syntastic settings
set statusline+=%#warningmsg#
set statusline+=%{SyntasticStatuslineFlag()}
set statusline+=%*

let g:syntastic_always_populate_loc_list = 1
let g:syntastic_auto_loc_list = 1
let g:syntastic_check_on_open = 1
let g:syntastic_check_on_wq = 0

"Ulti-snips settings
"" Trigger configuration. You need to change this to something other than
"<tab> if you use one of the following:
"" - https://github.com/Valloric/YouCompleteMe
"" - https://github.com/nvim-lua/completion-nvim
let g:UltiSnipsExpandTrigger="<tab>"
let g:UltiSnipsJumpForwardTrigger="<tab>"
let g:UltiSnipsJumpBackwardTrigger="<c-z>"
" If you want :UltiSnipsEdit to split your window.
let g:UltiSnipsEditSplit="vertical"

"vim-rainbow settings
let g:rainbow_active = 1

"template settings 
if has("autocmd")
    augroup templates
        autocmd BufNewFile *.cpp 0r ~/.vim/templates/skeleton.cpp
    augroup END
endif
